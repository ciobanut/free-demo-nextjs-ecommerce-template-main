DEMO_BEHAVORA_DEV_WS_PORT=443

# Behavora - Production Environment
DEMO_BEHAVORA_PROD_API_BASE_URL=https://app.behavora.com
DEMO_BEHAVORA_PROD_SCRIPT_SRC=https://cdn.behavora.com/widget/loader.js
DEMO_BEHAVORA_PROD_SITE_ID=your_prod_site_id

# Behavora - Local Development
DEMO_BEHAVORA_LOCAL_API_BASE_URL=http://localhost:8082
