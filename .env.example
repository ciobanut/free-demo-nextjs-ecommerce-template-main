# Behavora - Dev Environment
DEMO_BEHAVORA_DEV_API_BASE_URL=https://dev.behavora.com
DEMO_BEHAVORA_DEV_SCRIPT_SRC=https://dev-cdn.behavora.com/widget/loader.js
DEMO_BEHAVORA_DEV_SITE_ID=your_dev_site_id
DEMO_BEHAVORA_DEV_WS_KEY=your_dev_ws_key
